{
  "name": "matkorgen",
  "version": "1.0.0",
  "description": "MCP server for grocery shopping — search products and manage carts across Swedish grocery stores.",
  "main": "dist/server.js",
  "bin": {
    "matkorgen": "dist/server.js"
  },
  "files": [
    "dist/",
    "gemini-extension.json",
    "GEMINI.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/server.js",
    "lint": "eslint src/",
    "test": "tsc && vitest",
    "test:e2e": "tsc && vitest --config vitest.config.e2e.ts",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "grocery",
    "ica",
    "sweden",
    "playwright",
    "shopping-cart",
    "gemini-cli-extension"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
